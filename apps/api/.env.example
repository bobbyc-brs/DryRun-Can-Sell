# Local PostgreSQL — copy to `.env` in this directory (`apps/api/.env`).
# `prisma migrate` / `db push` need a reachable database.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cansell?schema=public"

# API bind (optional). Default dev port is 26<DD>1 (e.g. 26291 on the 29th).
# PORT=26291
# HOST=0.0.0.0
