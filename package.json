{
  "name": "can-sell",
  "private": true,
  "version": "0.0.0",
  "description": "Can-sell marketplace (web + API)",
  "author": "Brighter Sight Inc. <info@BrighterSight.ca>",
  "license": "GPL-3.0-or-later",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"npm run dev -w web\" \"npm run dev -w api\"",
    "build": "npm run build -w web && npm run build -w api",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "npm run lint -w web",
    "verify": "npm run build && npm test && npm run lint -w web",
    "prepare": "husky"
  },
  "devDependencies": {
    "@rolldown/binding-linux-x64-gnu": "^1.0.0-rc.12",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "esbuild": "^0.27.4",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "lightningcss-linux-x64-gnu": "^1.32.0",
    "vitest": "^3.2.4"
  }
}
